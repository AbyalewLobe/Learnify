# Test Environment Variables
NODE_ENV=test
PORT=3001
LOG_LEVEL=error

# Test Database (use a separate test database)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/learnify_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=learnify_db
DB_USER=postgres
DB_PASSWORD=postgres123

# Test Redis
REDIS_URL=redis://localhost:6379/1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# Test JWT Secrets
JWT_SECRET=test-jwt-secret-key
JWT_REFRESH_SECRET=test-refresh-secret-key

# Test Stripe (use test keys)
STRIPE_SECRET_KEY=sk_test_test_key
STRIPE_PUBLISHABLE_KEY=pk_test_test_key

# Test AWS (use test credentials or mocks)
AWS_ACCESS_KEY_ID=test_access_key
AWS_SECRET_ACCESS_KEY=test_secret_key
AWS_REGION=us-east-1

# Test S3 Buckets
S3_BUCKET_VIDEOS=learnify-videos-test
S3_BUCKET_RESOURCES=learnify-resources-test
S3_BUCKET_PUBLIC=learnify-public-test
S3_BUCKET_UPLOADS=learnify-uploads-test