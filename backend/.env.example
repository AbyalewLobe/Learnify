# Server Configuration
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/learnify_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=learnify_db
DB_USER=username
DB_PASSWORD=password
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# AWS S3 Configuration
S3_BUCKET_VIDEOS=learnify-videos-dev
S3_BUCKET_RESOURCES=learnify-resources-dev
S3_BUCKET_PUBLIC=learnify-public-dev
S3_BUCKET_UPLOADS=learnify-uploads-dev

# AWS CloudFront Configuration
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=your_key_pair_id
CLOUDFRONT_PRIVATE_KEY_PATH=./keys/cloudfront-private-key.pem

# AWS SES Configuration
SES_FROM_EMAIL=noreply@learnify.com
SES_FROM_NAME=Learnify Platform
SES_REGION=us-east-1

# AWS MediaConvert Configuration
MEDIACONVERT_ENDPOINT=https://your-account-id.mediaconvert.us-east-1.amazonaws.com
MEDIACONVERT_ROLE_ARN=arn:aws:iam::your-account:role/MediaConvertRole
MEDIACONVERT_QUEUE_ARN=arn:aws:mediaconvert:us-east-1:your-account:queues/Default

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_VIDEO_SIZE_MB=2048
MAX_RESOURCE_SIZE_MB=100
MAX_IMAGE_SIZE_MB=10

# Email Templates
EMAIL_TEMPLATE_WELCOME=welcome
EMAIL_TEMPLATE_PASSWORD_RESET=password-reset
EMAIL_TEMPLATE_ENROLLMENT_CONFIRMATION=enrollment-confirmation
EMAIL_TEMPLATE_COURSE_APPROVED=course-approved
EMAIL_TEMPLATE_COURSE_REJECTED=course-rejected
EMAIL_TEMPLATE_CERTIFICATE_GENERATED=certificate-generated

# Security
BCRYPT_SALT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# Analytics
ANALYTICS_BATCH_SIZE=1000
ANALYTICS_BATCH_INTERVAL_MS=300000